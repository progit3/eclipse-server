<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:style="clr-namespace:Content.Client.Stylesheets"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               MinSize="780 800"
               Title="{Loc 'seed-dna-window-title'}">
    <BoxContainer Orientation="Vertical">
        <GridContainer Columns="2" HorizontalExpand="True">
            <!-- Row 1 -->
            <GridContainer Columns="3" HorizontalExpand="True">
                <!-- Row 1 -->
                <Label Text="{Loc 'seed-dna-window-seed'}" />
                <Button Name="SeedButton" Access="Public" />
                <Label Name="SeedLabel" />

                <!-- Row 2 -->
                <Label Text="{Loc 'seed-dna-window-dnadisk'}" />
                <Button Name="DnaDiskButton" Access="Public" />
                <Label Name="DnaDiskLabel" />
            </GridContainer>

            <!-- Row 2 -->
            <BoxContainer Orientation="Horizontal" Margin="0 5 0 0"
                          HorizontalAlignment="Right" VerticalAlignment="Top">
                <TextureRect StyleClasses="RTLogoDark" Stretch="KeepAspectCentered"
                             VerticalAlignment="Center" HorizontalAlignment="Right" SetSize="19 19" />
                <Label Text="RatTech" StyleClasses="WindowFooterText" Margin="2 0 0 0" />
            </BoxContainer>
        </GridContainer>

        <controls:HLine Color="{x:Static style:StyleNano.NanoGold}" Thickness="2" Margin="0 5 0 5" />

        <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
            <!--
            Р’ СЃРІСЏР·Рё СЃ РѕСЃРѕР±РµРЅРЅРѕСЃС‚СЏРјРё РєРѕРґР° РІРёР·Р°СЂРґРѕРІ РїРѕ Р±РѕС‚Р°РЅРёРєРµ Рё РЅРµ РІРІРѕРґРѕРґРёС‚СЊ РёРіСЂРѕРєРѕРІ РІ Р·Р°Р±Р»СѓР¶РґРµРЅРёСЏ,
            РЅРµР»СЊР·СЏ РёСЃРїРѕР»СЊР·РѕРІР°С‚СЊ СЃРµРјРµРЅР° Сѓ РєРѕС‚РѕСЂС‹С… РЅРµ РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅС‹ "РјСѓС‚Р°С†РёРё".
            -->
            <Label Name="InvalidSeedLabel" Text="{Loc 'seed-dna-window-invalid-seed'}" Visible="False"/>
            <!--
            Р’РёР·Р°СЂРґС‹ РѕРїСЏС‚СЊ СЃР»РѕРјР°Р»Рё UI.
            "HSeparationOverride" РґРѕР»Р¶РµРЅ СѓРІРµР»РёС‡РёРІР°С‚СЊ РіРѕСЂРёР·РѕРЅС‚Р°Р»СЊРЅРѕРµ (H) СЂР°СЃСЃС‚РѕСЏРЅРёРµ РјРµР¶РґСѓ СЏС‡РµР№РєР°РјРё (СЌР»РµРјРµРЅС‚Р°РјРё).
            "VSeparationOverride" РґРѕР»Р¶РµРЅ СѓРІРµР»РёС‡РёРІР°С‚СЊ РІРµСЂС‚РёРєР°Р»СЊРЅРѕРµ (V) СЂР°СЃСЃС‚РѕСЏРЅРёРµ РјРµР¶РґСѓ СЏС‡РµР№РєР°РјРё (СЌР»РµРјРµРЅС‚Р°РјРё).
            РќРѕ РЅР° РґРµР»Рµ РІСЃС‘ РїСЂРѕРёСЃС…РѕРґРёС‚ РЅР°РѕР±РѕСЂРѕС‚, РЅРѕ РёР·-Р·Р° СЌС‚РѕРіРѕ "GridContainer" РЅРµ РїСЂР°РІРёР»СЊРЅРѕ РєРѕСЂСЂРµРєС‚РёСЂСѓРµС‚ РІРЅСѓС‚СЂРµРЅРЅРёРµ
            СЂР°Р·РјРµСЂС‹, Р° РїРѕС‚РѕРјСѓ РїСЂРё СЃРїРѕР»СЊР·РѕРІР°РЅРёРё "VSeparationOverride" РіРѕСЂРёР·РѕРЅС‚Р°Р»СЊРЅРѕРµ СЂР°СЃСЃС‚РѕСЏРЅРёРµ РјРµР¶РґСѓ СЌР»РµРјРµРЅС‚Р°РјРё СѓРІРµР»РёС‡РёРІР°РµС‚СЃСЏ,
            Р° С…Р°РѕРґРЅРѕ РїРѕСЏРІР»СЏРµС‚СЃСЏ РєСѓС‡Р° РїСѓСЃС‚РѕРіРѕ РїСЂРѕСЃС‚СЂР°РЅСЃС‚РІР° РїРѕСЃР»Рµ РїРѕСЃР»РµРґРЅРµР№ "СЃС‚СЂРѕРєРё" (row).
            РџРѕ СЌС‚РѕРјСѓ РїСЂРёС…РѕРґРёС‚СЃСЏ РІС‹РєСЂСѓС‡РёРІР°С‚СЊСЃСЏ Рё РїСЂРѕРїРёСЃС‹РІР°С‚СЊ "Margin" РґР»СЏ РєР°Р¶РґРѕР№ СЏС‡РµР№РєРё (СЌР»РµРјРµРЅС‚Р°).
            -->
            <!-- <GridContainer Name="MutationContainer" Columns="4" HorizontalExpand="True" VSeparationOverride="15"> -->
            <GridContainer Name="MutationContainer" Columns="4" HorizontalExpand="True">
                <!-- Body -->
            </GridContainer>
        </ScrollContainer>

        <controls:HLine Color="{x:Static style:StyleNano.NanoGold}" Thickness="2" Margin="0 5 0 5" />

        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Right" SeparationOverride="5">
            <Button Name="ExtractAllButton" Text="{Loc 'seed-dna-window-extract-all'}" Disabled="True" />
            <Button Name="ReplaceAllButton" Text="{Loc 'seed-dna-window-replace-all'}" Disabled="True" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>

