# Copy to /etc/eclipse-autoupdate.env and edit for the production server.

# Repository checkout on the server.
ROOT=/srv/eclipse-server

# GitHub branch to watch. Leave empty to use the current checked-out branch.
BRANCH=lobby

# GitHub repository and local remote.
REMOTE_URL=https://github.com/ShalnayaKlyaksa/eclipse-server.git
REMOTE=origin

# Robust status API. This is usually the same port as net.port.
STATUS_URL=http://127.0.0.1:1212

# Set a long random value here. The script passes it to the server as
# watchdog.token and uses it for POST /update.
WATCHDOG_TOKEN=change-me-to-a-long-random-secret

# Production command used to start the server.
# For source-run deployments:
SERVER_COMMAND=dotnet run --configuration Release --project Content.Server --

# For packaged deployments, use something like this instead:
# SERVER_COMMAND=/srv/eclipse-server/Robust.Server --config-file /srv/eclipse/config.toml --data-dir /srv/eclipse/data

# Optional command run after git pull and submodule update, before the server
# starts again. Leave empty for dotnet run deployments.
# POST_UPDATE_COMMAND=dotnet build --configuration Release --no-restore /p:WarningsAsErrors= /m

# Seconds between GitHub checks.
CHECK_INTERVAL=300

# Pulling with tracked local edits is refused by default.
ALLOW_DIRTY=0
